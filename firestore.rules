
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAgencyMember(agencyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/emergency_agencies/$(agencyId)/members/$(request.auth.uid));
    }

    function isReportParticipant(reportData) {
      return isOwner(reportData.reporterId) || isAgencyMember(reportData.receivingAgencyId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for personal and medical user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for emergency reports.
     * Note: allow list is simplified to isSignedIn() to avoid "rules are not filters" errors during prototype list views.
     */
    match /emergency_reports/{reportId} {
      allow get, list: if isSignedIn(); 
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isSignedIn() && (isReportParticipant(resource.data) || isAgencyMember(request.resource.data.receivingAgencyId));
      allow delete: if resource != null && isOwner(resource.data.reporterId);
    }

    /**
     * @description Rules for emergency response organizations.
     */
    match /emergency_agencies/{agencyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAgencyMember(agencyId);

      match /members/{memberId} {
        allow get: if isSignedIn();
        allow list: if isAgencyMember(agencyId);
        allow create, update, delete: if isAgencyMember(agencyId);
      }
    }

    /**
     * @description Rules for ambulance units managed by agencies.
     */
    match /ambulance_units/{unitId} {
      allow get, list: if isSignedIn();
      allow create: if isAgencyMember(request.resource.data.agencyId);
      allow update: if resource != null && (isAgencyMember(resource.data.agencyId) || isOwner(resource.data.driverId));
      allow delete: if resource != null && isAgencyMember(resource.data.agencyId);
    }

    /**
     * @description Rules for driver profiles.
     */
    match /drivers/{driverId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(driverId) && isAgencyMember(request.resource.data.agencyId);
      allow update: if isExistingOwner(driverId) && request.resource.data.agencyId == resource.data.agencyId;
      allow delete: if isExistingOwner(driverId);
    }

    /**
     * @description Publicly readable first aid guidelines.
     */
    match /first_aid_guidelines/{guidelineId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
