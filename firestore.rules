/**
 * Smart Paramedic Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a hybrid security model tailored for emergency response: 
 * private ownership for citizens and role-based access for emergency agency personnel. 
 * High priority is given to "Authorization Independence" via denormalization—all 
 * authorization metadata (userIds, agencyIds) is stored directly on documents to 
 * avoid expensive cross-document lookups.
 * 
 * DATA STRUCTURE:
 * - /users/{userId}: Private user profiles containing critical medical data.
 * - /emergency_reports/{reportId}: Shared incidents between a reporter and an agency.
 * - /emergency_agencies/{agencyId}: Organizational data with a /members subcollection for RBAC.
 * - /ambulance_units/{unitId} & /drivers/{driverId}: Operational assets linked to agencies.
 * - /first_aid_guidelines/{guidelineId}: Publicly accessible instructional content.
 * 
 * KEY SECURITY DECISIONS:
 * - Ownership: Citizens have full CRUD on their own profiles and reports.
 * - Agency Access: Personnel access is granted by verifying membership in a specific 
 *   agency via the /emergency_agencies/{agencyId}/members subcollection.
 * - Public Read: First aid guidelines are open to all users (including anonymous) 
 *   to ensure immediate access to life-saving information during emergencies.
 * - Relational Integrity: On creation, documents must match the authenticated user's 
 *   UID or the relevant path parameters to prevent data hijacking.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAgencyMember(agencyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/emergency_agencies/$(agencyId)/members/$(request.auth.uid));
    }

    function isReportParticipant(reportData) {
      return isOwner(reportData.reporterId) || isAgencyMember(reportData.receivingAgencyId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for personal and medical user profiles.
     * @path /users/{userId}
     * @allow (create) if the UID matches the path and data.
     * @deny (read) if the user is not the owner of the profile.
     * @principle Enforces strict document ownership and path-to-data consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for emergency reports shared between users and agencies.
     * @path /emergency_reports/{reportId}
     * @allow (list) if the user is the reporter or a member of the assigned agency.
     * @deny (create) if the reporterId in the data does not match the authenticated UID.
     * @principle Multi-party access based on denormalized IDs (reporterId/receivingAgencyId).
     */
    match /emergency_reports/{reportId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.reporterId) || isAgencyMember(resource.data.receivingAgencyId));
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if resource != null && isReportParticipant(resource.data);
      allow delete: if resource != null && isOwner(resource.data.reporterId);
    }

    /**
     * @description Rules for emergency response organizations.
     * @path /emergency_agencies/{agencyId}
     * @allow (get) for any signed-in user to find help.
     * @deny (write) if the user is not a verified member of that specific agency.
     * @principle Restricts organizational management to agency personnel.
     */
    match /emergency_agencies/{agencyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAgencyMember(agencyId);

      /**
       * @description Membership subcollection defining agency roles.
       * @path /emergency_agencies/{agencyId}/members/{memberId}
       */
      match /members/{memberId} {
        allow get: if isSignedIn();
        allow list: if isAgencyMember(agencyId);
        allow create, update, delete: if isAgencyMember(agencyId); // Prototyping: Members manage members
      }
    }

    /**
     * @description Rules for ambulance units managed by agencies.
     * @path /ambulance_units/{unitId}
     * @allow (update) if the user is the assigned driver or an agency member.
     * @deny (create) if the agencyId is not provided or valid.
     * @principle Agency-wide access for asset management and status updates.
     */
    match /ambulance_units/{unitId} {
      allow get, list: if isSignedIn();
      allow create: if isAgencyMember(request.resource.data.agencyId);
      allow update: if resource != null && (isAgencyMember(resource.data.agencyId) || isOwner(resource.data.driverId));
      allow delete: if resource != null && isAgencyMember(resource.data.agencyId);
    }

    /**
     * @description Rules for driver profiles and availability status.
     * @path /drivers/{driverId}
     * @allow (create) if the UID matches the driverId and user is an agency member.
     * @deny (update) if the agencyId is changed (immutable relation).
     * @principle Ensures drivers manage their own status while linked to an agency.
     */
    match /drivers/{driverId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(driverId) && isAgencyMember(request.resource.data.agencyId);
      allow update: if isExistingOwner(driverId) && request.resource.data.agencyId == resource.data.agencyId;
      allow delete: if isExistingOwner(driverId);
    }

    /**
     * @description Publicly readable first aid guidelines.
     * @path /first_aid_guidelines/{guidelineId}
     * @allow (read) for everyone (including anonymous users).
     * @deny (write) for all users through the client app.
     * @principle Read-only public resource for emergency education.
     */
    match /first_aid_guidelines/{guidelineId} {
      allow get, list: if true;
      allow create, update, delete: if false; // Guidelines managed via Admin/Console only
    }
  }
}